# MNEMOS Configuration
# Copy to .env and adjust as needed

# Retrieval tiers (comma-separated: chromadb, lancedb, colbert)
MNEMOS_TIERS=chromadb

# Embedding models
MNEMOS_EMBEDDING_MODEL=all-MiniLM-L6-v2
MNEMOS_COLBERT_MODEL=colbertv2.0

# TurboQuant compression (0 = disabled, 1-4 = bit-width)
MNEMOS_QUANT_BITS=4

# Forensic audit ledger
MNEMOS_AUDIT_ENABLED=true
MNEMOS_AUDIT_DB=data/audit.db
MNEMOS_AUDIT_RETENTION_DAYS=90

# API
MNEMOS_PORT=8700
MNEMOS_TOKEN=
MNEMOS_LOG_LEVEL=INFO
