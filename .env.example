# MNEMOS Configuration
# Copy to .env and adjust as needed

# Retrieval tiers (comma-separated: qdrant, lancedb, colbert)
MNEMOS_TIERS=qdrant

# Embedding models
MNEMOS_EMBEDDING_MODEL=all-MiniLM-L6-v2
MNEMOS_COLBERT_MODEL=colbertv2.0

# GPU device (cuda, cuda:0, cuda:1, cpu)
MNEMOS_GPU_DEVICE=cuda

# TurboQuant compression (0 = disabled, 1-4 = bit-width)
MNEMOS_QUANT_BITS=4

# Qdrant vector store
MNEMOS_QDRANT_URL=http://localhost:6333
MNEMOS_QDRANT_COLLECTION=mnemos_engrams

# PostgreSQL audit ledger (leave empty to fallback to SQLite)
MNEMOS_POSTGRES_DSN=postgresql://mnemos:mnemos@localhost:5432/mnemos_audit

# SQLite fallback (used when MNEMOS_POSTGRES_DSN is empty)
MNEMOS_AUDIT_DB=data/audit.db

# Forensic audit ledger
MNEMOS_AUDIT_ENABLED=true
MNEMOS_AUDIT_RETENTION_DAYS=90

# API
MNEMOS_PORT=8700
MNEMOS_TOKEN=
MNEMOS_LOG_LEVEL=INFO
